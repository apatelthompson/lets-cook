# ---- Airtable ----
# Personal access token from https://airtable.com/create/tokens
# Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat_xxx
# Base ID (looks like app...) from https://airtable.com/api
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_MESSAGES_TABLE=Messages
AIRTABLE_SUBSCRIBERS_TABLE=Subscribers
AIRTABLE_SENDLOG_TABLE=SendLog

# ---- Twilio (SMS/MMS) ----
# From the Twilio console home: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Your purchased Twilio phone number in E.164 format, e.g. +14243221233
TWILIO_FROM_NUMBER=
# Optional: set to "1" to log messages locally instead of hitting Twilio.
# Useful until you have live credentials.
TWILIO_MOCK=1

# ---- Cron protection ----
# A random string; Vercel Cron will send this as the Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# ---- Defaults ----
DEFAULT_TIMEZONE=America/Los_Angeles
DELIVERY_HOUR=10
PROGRAM_LENGTH_DAYS=28

# ---- Anthropic (Mission Matrix Part II audition suggestions) ----
# From the Anthropic Console: console.anthropic.com → API Keys
# Used by /api/audition/suggest. Without it, the "Get AI suggestions"
# button in /mission-matrix/playground-v2 shows a friendly error.
ANTHROPIC_API_KEY=sk-ant-xxx
