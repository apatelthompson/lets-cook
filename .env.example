# ---- Airtable ----
# Personal access token from https://airtable.com/create/tokens
# Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat_xxx
# Base ID (looks like app...) from https://airtable.com/api
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_MESSAGES_TABLE=Messages
AIRTABLE_SUBSCRIBERS_TABLE=Subscribers
AIRTABLE_SENDLOG_TABLE=SendLog

# ---- Sendblue (iMessage) ----
# https://sendblue.co — dashboard -> API Keys
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
# Your provisioned Sendblue "Send from" number in E.164 format, e.g. +17862847802.
# Optional if your Sendblue account has exactly one number; required otherwise.
SENDBLUE_FROM_NUMBER=
# Optional: set to "1" to log messages locally instead of hitting Sendblue.
# Useful until you have live credentials.
SENDBLUE_MOCK=1

# ---- Cron protection ----
# A random string; Vercel Cron will send this as the Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# ---- Defaults ----
DEFAULT_TIMEZONE=America/Los_Angeles
DELIVERY_HOUR=10
PROGRAM_LENGTH_DAYS=28
